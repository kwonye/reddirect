{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extName__",
  "short_name": "__MSG_extShortName__",
  "version": "1.0.0",
  "description": "__MSG_extDescription__",
  "minimum_chrome_version": "114",
  "homepage_url": "https://github.com/kwonye/reddirect",
  "permissions": [
    "declarativeNetRequest"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "subdomain_redirects",
        "enabled": true,
        "path": "rules/subdomain-redirects.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "*://*.reddit.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*"
      ],
      "js": [
        "redirect-core.js",
        "content-redirect.js"
      ],
      "run_at": "document_start"
    }
  ]
}
